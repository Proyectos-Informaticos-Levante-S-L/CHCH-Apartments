---
---

<section id="inicio" class="relative overflow-hidden border-b border-[var(--color-arena-oscuro)]">
  <div class="relative mx-auto min-h-[460px] max-w-6xl md:min-h-[520px]">

    <!-- Mapa decorativo: solo en el 40% derecho, se desvanece hacia la izquierda -->
    <div class="pointer-events-none absolute inset-y-0 right-0 z-0 hidden w-2/5 md:block" aria-hidden="true">
      <svg viewBox="0 0 240 360" preserveAspectRatio="xMidYMid slice" class="h-full w-full">
        <defs>
          <linearGradient id="fadeMapa" x1="0" y1="0" x2="1" y2="0">
            <stop offset="0%"   stop-color="#faf8f5" stop-opacity="1"/>
            <stop offset="55%"  stop-color="#faf8f5" stop-opacity="0.45"/>
            <stop offset="85%"  stop-color="#faf8f5" stop-opacity="0.05"/>
            <stop offset="100%" stop-color="#faf8f5" stop-opacity="0"/>
          </linearGradient>
          <mask id="maskMapa">
            <rect x="0" y="0" width="240" height="360" fill="white"/>
            <rect x="0" y="0" width="240" height="360" fill="url(#fadeMapa)"/>
          </mask>
        </defs>
        <g mask="url(#maskMapa)" stroke="#9a948c" stroke-width="1" fill="none" opacity="0.85">
          <path d="M30 -20 L110 380"/>
          <path d="M120 -20 L190 380"/>
          <path d="M210 -20 L250 380"/>
          <path d="M-20 50 L260 80"/>
          <path d="M-20 150 L260 125"/>
          <path d="M-20 250 L260 290"/>
          <path d="M-20 330 L260 350"/>
          <path d="M-20 150 C 100 125, 180 130, 260 125" stroke="#7d776f" stroke-width="1.3"/>
          <path d="M70 -20 C 90 120, 120 240, 160 380" stroke="#7d776f" stroke-width="1.3"/>
        </g>
        <g mask="url(#maskMapa)" fill="none" stroke="#b3ada4" stroke-width="0.9">
          <rect x="90" y="90" width="52" height="48"/>
          <rect x="170" y="175" width="55" height="46"/>
          <rect x="85" y="225" width="48" height="56"/>
          <rect x="180" y="90" width="46" height="40"/>
        </g>
        <g mask="url(#maskMapa)" fill="#7d776f">
          <circle cx="150" cy="135" r="4.5"/>
          <circle cx="200" cy="90" r="3"/>
          <circle cx="110" cy="290" r="3"/>
        </g>
      </svg>
    </div>

    <!-- Texto: 60% izquierdo -->
    <div class="relative z-10 px-6 py-16 md:w-3/5 md:py-24">
      <p class="mb-4 text-xs font-medium uppercase tracking-[0.2em] text-[var(--color-oliva)]">
        Apartamentos vacacionales
      </p>

      <h1 class="font-display text-5xl font-semibold leading-[1.05] tracking-tight text-[var(--color-tinta)] md:text-6xl">
        Tu escapada perfecta,<br />
        <span class="italic font-medium text-[var(--color-terracota)]">empieza aquí</span>
      </h1>

      <p class="mt-6 max-w-md text-base leading-relaxed text-[var(--color-gris)]">
        Apartamentos con encanto para tus vacaciones, totalmente equipados
        y en las mejores zonas. Elige fechas y reserva en un minuto.
      </p>

      <div class="mt-8 flex flex-col items-start gap-3 sm:flex-row">

        <a  href="#apartamentos"
            class="rounded-full bg-[var(--color-terracota)] px-7 py-3 text-sm font-medium text-white transition hover:bg-[var(--color-terracota-oscuro)]"
        >
          Ver alojamientos
        </a>

        <a  href="#solicitud"
            class="rounded-full border border-[var(--color-tinta)] px-7 py-3 text-sm font-medium text-[var(--color-tinta)] transition hover:bg-[var(--color-tinta)] hover:text-[var(--color-arena)]"
        >
          Reservar estancia
        </a>
      </div>
    </div>

  </div>
</section>