---
import { Image } from "astro:assets";
import mapaHero from "../assets/mapa-hero.png";
---

<section id="inicio" class="relative overflow-hidden">

  <!-- Mapa decorativo IZQUIERDA: muestra la parte izquierda de la imagen, se desvanece hacia el centro. -->
  <div class="pointer-events-none absolute inset-y-0 left-0 z-0 hidden w-1/5 md:block" aria-hidden="true">
    <Image
      src={mapaHero}
      alt=""
      class="h-full w-full object-cover object-left"
      style="filter: contrast(1); -webkit-mask-image: linear-gradient(to left, transparent 0%, rgba(0,0,0,0.35) 50%, black 100%); mask-image: linear-gradient(to left, transparent 0%, rgba(0,0,0,0.35) 50%, black 100%);"
    />
  </div>

  <!-- Mapa decorativo DERECHA: muestra la parte derecha de la imagen, se desvanece hacia el centro. -->
  <div class="pointer-events-none absolute inset-y-0 right-0 z-0 hidden w-1/2 md:block" aria-hidden="true">
    <Image
      src={mapaHero}
      alt=""
      class="h-full w-full object-cover object-right"
      style="filter: contrast(1); -webkit-mask-image: linear-gradient(to right, transparent 0%, rgba(0,0,0,0.35) 50%, black 100%); mask-image: linear-gradient(to right, transparent 0%, rgba(0,0,0,0.35) 50%, black 100%);"
    />
  </div>

  <!-- Texto -->
  <div class="relative z-10 mx-auto max-w-6xl px-6 py-16 md:py-24">
    <div class="md:w-3/5">
      <p class="mb-4 text-xs font-medium uppercase tracking-[0.2em] text-[var(--color-oliva)]">
        Apartamentos vacacionales
      </p>

      <h1 class="font-display text-5xl font-semibold leading-[1.05] tracking-tight text-[var(--color-tinta)] md:text-6xl">
        Tu escapada perfecta,<br />
        <span class="italic font-medium text-[var(--color-terracota)]">empieza aquí</span>
      </h1>

      <p class="mt-6 max-w-md text-base leading-relaxed text-[var(--color-gris)]">
        Apartamentos con encanto para tus vacaciones, totalmente equipados
        y en las mejores zonas. Elige fechas y reserva en un minuto.
      </p>

      <div class="mt-8 flex flex-col items-start gap-3 sm:flex-row">
        <a  href="#apartamentos"
            class="rounded-full bg-[var(--color-terracota)] px-7 py-3 text-sm font-medium text-white transition hover:bg-[var(--color-terracota-oscuro)]"
        >
          Ver alojamientos
        </a>
      </div>
    </div>
  </div>

</section>