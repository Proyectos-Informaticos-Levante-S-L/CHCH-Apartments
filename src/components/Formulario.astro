---
---

<section id="solicitud" class="bg-[var(--color-tinta)] py-20 text-white">
  <div class="mx-auto grid max-w-6xl gap-12 px-6 md:grid-cols-2">

    <!-- Texto lateral -->
    <div>
      <p class="mb-2 text-xs font-medium uppercase tracking-[0.2em] text-[var(--color-terracota)]">
        Contacto
      </p>
      <h2 class="font-display text-4xl font-semibold tracking-tight">
        ¿Hablamos?
      </h2>
      <p class="mt-6 max-w-md text-white/70">
        Estaremos encantados de atenderte. Escríbenos con cualquier consulta o
        comentario y te responderemos lo antes posible.
      </p>

      <div class="mt-10 space-y-4 text-sm text-white/80">
        <p class="flex items-center gap-3">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="text-[var(--color-terracota)]">
            <rect x="2" y="4" width="20" height="16" rx="2" />
            <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7" />
          </svg>
          hola@chchapartments.com
        </p>
        <p class="flex items-center gap-3">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="text-[var(--color-terracota)]">
            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.9.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z" />
          </svg>
          600 123 456
        </p>
      </div>
    </div>

    <!-- Formulario -->
    <form
      id="form-contacto"
      action="https://formspree.io/f/TU_ID"
      method="POST"
      class="space-y-5 rounded-3xl bg-[var(--color-crema)]/95 p-8 text-[var(--color-tinta)] backdrop-blur"
      novalidate
    >
      <!-- Nombre + Apellidos -->
      <div class="grid gap-5 sm:grid-cols-2">
        <div>
          <label for="nombre" class="mb-1.5 block text-sm font-medium">
            Nombre <span class="text-[var(--color-terracota)]">*</span>
          </label>
          <input
            type="text" id="nombre" name="nombre" required
            class="w-full rounded-xl border border-[var(--color-arena-oscuro)] bg-white/80 px-4 py-3 text-sm outline-none transition focus:border-[var(--color-terracota)] focus:bg-white"
            placeholder="Tu nombre"
          />
          <p class="error mt-1 hidden text-xs text-red-600"></p>
        </div>
        <div>
          <label for="apellidos" class="mb-1.5 block text-sm font-medium">
            Apellidos <span class="text-[var(--color-terracota)]">*</span>
          </label>
          <input
            type="text" id="apellidos" name="apellidos" required
            class="w-full rounded-xl border border-[var(--color-arena-oscuro)] bg-white/80 px-4 py-3 text-sm outline-none transition focus:border-[var(--color-terracota)] focus:bg-white"
            placeholder="Tus apellidos"
          />
          <p class="error mt-1 hidden text-xs text-red-600"></p>
        </div>
      </div>

      <!-- Email + Teléfono -->
      <div class="grid gap-5 sm:grid-cols-2">
        <div>
          <label for="email" class="mb-1.5 block text-sm font-medium">
            Correo electrónico <span class="text-[var(--color-terracota)]">*</span>
          </label>
          <input
            type="email" id="email" name="email" required
            class="w-full rounded-xl border border-[var(--color-arena-oscuro)] bg-white/80 px-4 py-3 text-sm outline-none transition focus:border-[var(--color-terracota)] focus:bg-white"
            placeholder="tu@email.com"
          />
          <p class="error mt-1 hidden text-xs text-red-600"></p>
        </div>
        <div>
          <label for="telefono" class="mb-1.5 block text-sm font-medium">
            Teléfono <span class="text-[var(--color-gris)]">(opcional)</span>
          </label>
          <input
            type="tel" id="telefono" name="telefono"
            class="w-full rounded-xl border border-[var(--color-arena-oscuro)] bg-white/80 px-4 py-3 text-sm outline-none transition focus:border-[var(--color-terracota)] focus:bg-white"
            placeholder="600 000 000"
          />
        </div>
      </div>

      <!-- Mensaje -->
      <div>
        <label for="mensaje" class="mb-1.5 block text-sm font-medium">
          ¿En qué podemos ayudarte? <span class="text-[var(--color-terracota)]">*</span>
        </label>
        <textarea
          id="mensaje" name="mensaje" rows="4" required
          class="w-full rounded-xl border border-[var(--color-arena-oscuro)] bg-white/80 px-4 py-3 text-sm outline-none transition focus:border-[var(--color-terracota)] focus:bg-white"
          placeholder="Escríbenos tu consulta o comentario..."
        ></textarea>
        <p class="error mt-1 hidden text-xs text-red-600"></p>
      </div>

      <button
        type="submit"
        class="w-full rounded-full bg-[var(--color-terracota)] px-6 py-3.5 text-sm font-medium text-white transition hover:bg-[var(--color-terracota-oscuro)]"
      >
        Enviar mensaje
      </button>

      <p id="form-ok" class="hidden rounded-xl bg-[var(--color-oliva)]/10 px-4 py-3 text-center text-sm font-medium text-[var(--color-oliva)]">
        ✓ ¡Mensaje enviado! Te responderemos pronto.
      </p>
    </form>

  </div>
</section>

<script>
  const form = document.getElementById("form-contacto") as HTMLFormElement;
  const okMsg = document.getElementById("form-ok") as HTMLElement;

  // --- Validación ---
  const reglas: Record<string, string> = {
    nombre: "Por favor, introduce tu nombre.",
    apellidos: "Por favor, introduce tus apellidos.",
    email: "Por favor, introduce un correo válido.",
    mensaje: "Por favor, escribe tu mensaje.",
  };

  function validarCampo(campo: string): boolean {
    const input = form.elements.namedItem(campo) as HTMLInputElement | HTMLTextAreaElement;
    const error = input.parentElement?.querySelector(".error") as HTMLElement | null;
    let valido = input.value.trim() !== "";

    if (campo === "email" && valido) {
      valido = /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(input.value.trim());
    }

    if (!valido) {
      input.classList.add("border-red-500");
      if (error) {
        error.textContent = reglas[campo];
        error.classList.remove("hidden");
      }
    } else {
      input.classList.remove("border-red-500");
      if (error) error.classList.add("hidden");
    }
    return valido;
  }

  function resetearTodo() {
    form.reset();
  }

  form.addEventListener("submit", (e) => {
    e.preventDefault();
    let todoOk = true;
    for (const campo in reglas) {
      if (!validarCampo(campo)) todoOk = false;
    }

    if (!todoOk) return;

    if (!form.action.includes("TU_ID")) {
      fetch(form.action, {
        method: "POST",
        body: new FormData(form),
        headers: { Accept: "application/json" },
      })
        .then((res) => {
          if (res.ok) {
            resetearTodo();
            okMsg.classList.remove("hidden");
          }
        })
        .catch(() => {});
    } else {
      resetearTodo();
      okMsg.classList.remove("hidden");
    }
  });

  for (const campo in reglas) {
    const el = form.elements.namedItem(campo) as HTMLElement;
    el.addEventListener("input", () => validarCampo(campo));
  }
</script>